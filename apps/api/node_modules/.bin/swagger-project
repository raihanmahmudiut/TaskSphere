#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/work/TaskSphere/node_modules/.pnpm/swagger@0.7.5/node_modules/swagger/node_modules:/mnt/d/work/TaskSphere/node_modules/.pnpm/swagger@0.7.5/node_modules:/mnt/d/work/TaskSphere/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/work/TaskSphere/node_modules/.pnpm/swagger@0.7.5/node_modules/swagger/node_modules:/mnt/d/work/TaskSphere/node_modules/.pnpm/swagger@0.7.5/node_modules:/mnt/d/work/TaskSphere/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../swagger/bin/swagger-project.js" "$@"
else
  exec node  "$basedir/../swagger/bin/swagger-project.js" "$@"
fi
