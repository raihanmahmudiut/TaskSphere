{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": ["ts-jest", { "tsconfig": "tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^@app/(.*)$": "<rootDir>/src/$1",
    "^src/(.*)$": "<rootDir>/src/$1",
    "^@tasksphere/db$": "<rootDir>/../../packages/db/src/index.ts",
    "^@tasksphere/db/(.*)$": "<rootDir>/../../packages/db/src/$1"
  },
  "setupFilesAfterEnv": ["<rootDir>/setup-jest.js"]
}
