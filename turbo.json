{
  "$schema": "https://turbo.build/schema.json",

  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "build/**"]
    },

    "lint": {
      "dependsOn": ["^lint"]
    },

    "typecheck": {},

    "format:check": {},

    "test": {
      "dependsOn": ["build"]
    },

    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
